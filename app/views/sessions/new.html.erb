<h1>Sign in</h1>

<%= form_with url: session_path do |form| %>
  <div>
    <%= form.label :email %><br>
    <%= form.email_field :email, required: true %>
  </div>

  <div>
    <%= form.label :password %><br>
    <%= form.password_field :password, required: true %>
  </div>

  <div>
    <%= form.submit "Sign in" %>
  </div>
<% end %>

<p>
  New here?
  <%= link_to "Create account", new_signup_path %>
</p>
